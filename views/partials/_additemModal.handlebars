<div id="add-item-modal" class="modal">
    <div class="modal-content">
      <h2>Add New Stock Item</h2>
      <div id="stock-message-container" class="message-container"></div>
      <form id="add-item-form" method="POST" action="/api/stocks" enctype="multipart/form-data">
        <label for="new-item-name">Item Name</label>
        <input type="text" id="new-item-name" required>
        
        <label for="new-item-qty">Quantity</label>
        <input type="number" id="new-item-qty" min="0" value="0" required>

        <label for="new-item-cost">Cost Price</label>
        <input type="number" id="new-item-cost" min="0"  required>

        <label for="new-item-price">Selling Price</label>
        <input type="number" id="new-item-price" min="0"  required>
        
        <label for="item-image" style="cursor: pointer; display: block; text-align: center; margin-top: 10px; color: #555;">
          <span id="upload-placeholder-text"><i class="fa-solid fa-camera"></i> Tap to add image</span>
          <img id="image-preview" src="" alt="Preview" style="display: none; width: 100%; height: 120px; object-fit: cover; border-radius: 8px; margin-top: 10px;">
        </label>
        <input type="file" id="item-image" name="productImage" accept="image/*" style="display: none;">
        
        <div class="form-actions">
          <button type="button" class="cancel-btn tactile-btn" id="stock-cancel">Cancel</button>
          <button type="submit" class="save-btn tactile-btn" id="stock-save-btn">Save Item</button>
        </div>
      </form>
    </div>
  </div>