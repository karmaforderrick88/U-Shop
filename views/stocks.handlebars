 
 <main>
 <section id="stock-controls">
            <button id="add-stock-btn">+ Add Item
            </button>
            <input type="text" id="search-stock" placeholder="Search stock...">
        </section>
        <!-- Add Item Modal -->
{{> _additemModal}}



        <div id="stock-summary">
            <div class="summary-card">
                <h3>Total Items</h3>
                <p><span id="total-items"></span></p></p>
            </div>
            <div class="summary-card low-stock">
                <h3>Low Stock (&lt;5) </h3>
                <p id="low-stock-count"></p>
            </div>
        </div>
        <div class="table-responsive">
        <table id="stock-table">
            <thead>
                <tr>
                    <th>Item</th>
                    <th>Quantity</th>
                    <th>Selling Price</th>
                    <th>Cost Price</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody><!-- Filled by JS --></tbody>
        </table>
        {{> _deleteStockModal}}
    </div>
    
    <!-- Access Denied Modal -->
{{>_accessDenied}}
 </main>